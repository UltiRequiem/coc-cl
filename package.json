{
  "name": "coc-cl",
  "version": "1.0.0",
  "description": "Common Lisp language server provider extension using cl-lsp for coc.nvim",
  "funding": {
    "type": "patreon",
    "url": "https://www.patreon.com/ultirequiem"
  },
  "repository": "github:ultirequiem/coc-cl",
  "author": "Eliaz Bobadilla <eliaz.bobadilladev@gmail.com>",
  "license": "MIT",
  "main": "lib/index.js",
  "keywords": [
    "coc.nvim",
    "common-lisp",
    "lisp"
  ],
  "engines": {
    "coc": ">=0.0.82"
  },
  "scripts": {
    "lint": "xo src",
    "clean": "rimraf lib",
    "watch": "tsdown --watch",
    "build": "tsdown",
    "prepare": "tsdown"
  },
  "devDependencies": {
    "@types/node": "^14.14.0",
    "coc.nvim": "0.0.83-next.9",
    "rimraf": "^6.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0",
    "xo": "^0.60.0"
  },
  "activationEvents": [
    "onLanguage:lisp"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cl.interrupt",
        "title": "CL: Interrupt"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "coc-cl",
      "properties": {
        "cl.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable coc-cl extension"
        },
        "cl.serverPath": {
          "type": "string",
          "default": "cl-lsp",
          "description": "Path to the cl-lsp executable. Overrides the PATH lookup."
        },
        "cl.serverArguments": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments to pass to cl-lsp. Argument keys and values should be provided as separate entries e.g. ['--log-level', 'debug']"
        },
        "cl.toolchainPath": {
          "type": "string",
          "default": "",
          "description": "(optional) Path of the Lisp toolchain. By default, cl-lsp uses the toolchain it is installed in."
        },
        "cl.maxNumberOfProblems": {
          "type": "number",
          "default": 100,
          "description": "Controls the maximum number of problems produced by the server."
        },
        "cl.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between coc.nvim and the cl-lsp service."
        }
      }
    }
  },
  "snippets": [
    {
      "language": "lisp",
      "path": "./src/snippets.json"
    }
  ],
  "xo": {
    "rules": {
      "import/extensions": "off",
      "@typescript-eslint/naming-convention": "off"
    }
  }
}
